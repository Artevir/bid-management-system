.env
.env.local
.env.*.local

# 日志
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 构建产物
.next/
out/
dist/
build/

# 临时文件
tmp/
temp/
*.tmp

# 系统文件
.DS_Store
Thumbs.db

# 数据库
*.sqlite
*.db

# 压缩包
*.zip
*.tar.gz
*.rar

# 节点模块 (在构建时安装)
node_modules/

# pnpm
pnpm-debug.log
.pnpm-store/

# TypeScript
*.tsbuildinfo