# ============================================
# 环境变量配置
# ============================================

# ============================================
# 应用配置
# ============================================
NODE_ENV=production
PORT=5000
HOSTNAME=0.0.0.0
COZE_PROJECT_DOMAIN_DEFAULT=https://your-domain.com

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/bid_platform?schema=public
POSTGRES_USER=bid_platform
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=bid_platform

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ============================================
# WebSocket 配置
# ============================================
NEXT_PUBLIC_WS_URL=ws://localhost:5000
WS_PATH=/socket.io

# ============================================
# 对象存储配置（可选）
# ============================================
OSS_ENDPOINT=https://oss.example.com
OSS_ACCESS_KEY_ID=your_access_key
OSS_ACCESS_KEY_SECRET=your_secret_key
OSS_BUCKET=bid-platform-uploads
MAX_FILE_SIZE=1073741824

# ============================================
# 监控和日志
# ============================================
SENTRY_DSN=https://xxx@sentry.io/xxx
LOG_LEVEL=info
ENABLE_APM=true

# ============================================
# 安全配置
# ============================================
JWT_SECRET=your_jwt_secret_change_in_production
SESSION_SECRET=your_session_secret_change_in_production
ENCRYPTION_KEY=your_encryption_key_change_in_production

# ============================================
# 功能开关
# ============================================
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_REALTIME_NOTIFICATIONS=true
ENABLE_CACHE=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_MULTI_TENANT=false

# ============================================
# 性限流配置
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# ============================================
# 文件上传配置
# ============================================
CHUNK_SIZE=5242880
TEMP_DIR=/tmp/uploads
