loglevel=error
registry=https://registry.npmmirror.com

strictStorePkgContentCheck=false
verifyStoreIntegrity=false

# 网络优化
network-concurrency=16
fetch-retries=3
fetch-timeout=60000

# 严格使用 peer dependencies
strict-peer-dependencies=false

# 自动生成 lockfile
auto-install-peers=true

# lockfile 配置
lockfile=true
prefer-frozen-lockfile=true

# 如果 lockfile 存在但过期，更新而不是失败
resolution-mode=highest

# 兼容跨平台/跨架构部署（如 Windows 开发 + Linux 构建）
# 避免 Tailwind v4 的平台相关可选依赖（@tailwindcss/oxide-*）在 Linux 构建环境缺失
supportedArchitectures.os=linux,win32,darwin
supportedArchitectures.cpu=x64,arm64
supportedArchitectures.libc=glibc,musl
